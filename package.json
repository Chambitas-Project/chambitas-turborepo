{
  "name": "chambitas-monorepo",
  "private": true,
  "packageManager": "pnpm@8.15.5",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:gen": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > libs/shared-types/src/supabase.ts"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.8.0",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  }
}